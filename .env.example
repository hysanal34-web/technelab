# ─────────────────────────────────────────
# TECHNE LAB — Ortam Değişkenleri Şablonu
# Bu dosyayı .env.local olarak kopyalayın
# cp .env.example .env.local
# ─────────────────────────────────────────

# Site URL
NEXT_PUBLIC_SITE_URL=https://technelab.ist

# ── Ödeme (PayTR) ──────────────────────
# https://www.paytr.com
PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt

# ── AI Görsel Üretimi (Fal.ai) ─────────
# https://fal.ai → Dashboard → API Keys
FAL_KEY=your_fal_api_key

# ── AI Görsel Düzenleme (Nano Banana) ──
# https://banana.dev → API Keys
BANANA_API_KEY=your_banana_api_key

# ── E-posta Outreach (Instantly.ai) ────
# https://instantly.ai (opsiyonel)
INSTANTLY_API_KEY=your_instantly_api_key

# ── Başvuru Formu E-postası (Gmail SMTP) ──
# Kurulum: Google Hesabı → Güvenlik → 2 Adımlı Doğrulama → Uygulama Şifreleri
# "Mail" için 16 haneli uygulama şifresi oluştur, aşağıya yapıştır
GMAIL_USER=techne.lab.istanbul@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
